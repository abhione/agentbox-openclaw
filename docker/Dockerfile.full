# OpenClaw AgentBox - Full Image with VNC Screen Sharing
# "Zoom for Agents" - See what your agents see

FROM node:22-bookworm-slim

LABEL maintainer="OpenClaw"
LABEL description="OpenClaw agent container with VNC screen sharing"

# Install all dependencies in one layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Process utilities
    procps \
    # Basic tools
    curl wget git ca-certificates gnupg \
    # VNC and desktop
    tigervnc-standalone-server tigervnc-common \
    novnc websockify \
    openbox \
    xterm \
    # Browser dependencies
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 \
    libxrandr2 libgbm1 libasound2 libpango-1.0-0 libcairo2 \
    # Python for scripts
    python3 python3-pip \
    # Process management
    supervisor \
    # Fonts
    fonts-liberation fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash -u 1001 agent && \
    mkdir -p /home/agent/.openclaw /home/agent/.vnc /workspace && \
    chown -R agent:agent /home/agent /workspace

# Install OpenClaw globally
RUN npm install -g openclaw@latest

# Install Chromium for browser automation
RUN npx playwright install chromium --with-deps || true

# VNC setup
COPY --chown=agent:agent vnc/xstartup /home/agent/.vnc/xstartup
RUN chmod +x /home/agent/.vnc/xstartup

# Supervisor config for process management (needs read perms for all)
COPY --chmod=644 supervisor/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Entrypoint
COPY --chmod=755 entrypoint.sh /entrypoint.sh

# Ports
# 18789 - OpenClaw Gateway
# 18791 - Browser Control
# 5901  - VNC
# 6080  - noVNC (web)
EXPOSE 18789 18791 5901 6080

# Pre-create config structure as root, then set permissions
RUN mkdir -p /home/agent/.openclaw/workspace \
    /home/agent/.openclaw/credentials \
    /home/agent/.openclaw/agents && \
    chown -R agent:agent /home/agent/.openclaw

WORKDIR /workspace

ENV DISPLAY=:1
ENV HOME=/home/agent

ENTRYPOINT ["/entrypoint.sh"]
CMD ["openclaw", "gateway", "run"]
