# OpenClaw Agent Box - Base Image
# Provides isolated OpenClaw/Hermes agent environment with:
# - Node.js 22 runtime
# - OpenClaw gateway pre-installed
# - VNC for screen sharing (noVNC web viewer)
# - Chromium for browser automation

FROM node:22-bookworm-slim

LABEL maintainer="OpenClaw <support@openclaw.ai>"
LABEL org.opencontainers.image.description="OpenClaw agent runtime for AgentBox"

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core utils
    curl wget git ca-certificates gnupg \
    # VNC + desktop
    tigervnc-standalone-server tigervnc-common \
    novnc websockify \
    fluxbox xterm \
    # Browser
    chromium chromium-sandbox \
    # Python for skills
    python3 python3-pip python3-venv \
    # Build tools
    build-essential \
    # Cleanup
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash -u 1000 agent && \
    mkdir -p /home/agent/.openclaw /workspace && \
    chown -R agent:agent /home/agent /workspace

# Install OpenClaw globally
RUN npm install -g openclaw@latest

# Install Hermes (Python agent framework)
RUN pip3 install --break-system-packages hermes-agent || true

# VNC setup
ENV DISPLAY=:1
ENV VNC_PORT=5901
ENV NOVNC_PORT=6080

# Copy startup scripts
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY start-vnc.sh /usr/local/bin/start-vnc.sh
RUN chmod +x /usr/local/bin/*.sh

# Agent ports
# 18789: OpenClaw gateway
# 18791: Browser control
# 5901: VNC
# 6080: noVNC web
EXPOSE 18789 18791 5901 6080

USER agent
WORKDIR /workspace

# Pre-create config structure
RUN mkdir -p /home/agent/.openclaw/workspace \
    /home/agent/.openclaw/credentials \
    /home/agent/.openclaw/skills

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["openclaw", "gateway", "run"]
